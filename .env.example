# --- Base de données ---
# Si vous changez ces valeurs après un premier lancement Docker, exécutez :
#   docker compose down -v
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=app

# --- Backend ---
MODEL_PATH=models/model.pkl

# --- Modèle ML sur S3 (laisser vide en local pour utiliser le fallback) ---
# MODEL_S3_BUCKET=2ie-groupeX-models
# MODEL_S3_KEY=model.pkl

# --- AWS ---
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=votre-account-id
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Authentification Google (espace admin) ---
# Client ID : Google Cloud Console > APIs & Services > Credentials
# Ajouter http://localhost:5173 dans les origins autorisées du client OAuth
GOOGLE_CLIENT_ID=votre-client-id.apps.googleusercontent.com
# Générer avec : openssl rand -hex 32
JWT_SECRET=changeme-generer-une-vraie-cle-aleatoire
ADMIN_EMAILS=admin@example.com

# --- Frontend ---
VITE_API_URL=/api
VITE_GOOGLE_CLIENT_ID=votre-client-id.apps.googleusercontent.com

# --- Docker Hub (configurer dans GitHub > Settings > Secrets, pas ici) ---
DOCKERHUB_USERNAME=votre-user-dockerhub
DOCKERHUB_TOKEN=
BACKEND_REPO=projet-cloud-backend
FRONTEND_REPO=projet-cloud-frontend
IMAGE_TAG=latest

# --- CI/CD AWS (configurer dans GitHub > Settings > Secrets) ---
# AWS_ROLE_TO_ASSUME=arn:aws:iam::ACCOUNT:role/github-actions-deploy

# --- S3 modèle ML ---
MODEL_S3_BUCKET=2ie-groupeX-models
MODEL_S3_KEY=model.pkl
